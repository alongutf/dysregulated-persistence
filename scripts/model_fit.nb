Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"a", "[", "\[Alpha]_", "]"}], ":=", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SqrtBox["\[Alpha]"]}], ")"}], "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"b", "[", "\[Alpha]_", "]"}], ":=", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SqrtBox["\[Alpha]"]}], ")"}], "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"k", "[", 
    RowBox[{"\[Lambda]_", ",", "\[Alpha]_"}], "]"}], ":=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"2", "\[Pi]", " ", "\[Lambda]", " ", "\[Alpha]"}]], 
    SqrtBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"a", "[", "\[Alpha]", "]"}], "-", "\[Lambda]"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "-", 
        RowBox[{"b", "[", "\[Alpha]", "]"}]}], ")"}]}]]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"k", "[", 
      RowBox[{"\[Lambda]", ",", "\[Alpha]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Lambda]", ",", "0", ",", "5"}], "}"}], ",", 
     RowBox[{"Filling", "\[Rule]", "Bottom"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\[Lambda]", ",", "\"\<\[Rho](\[Lambda])\>\""}], "}"}]}]}], 
    "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Alpha]", ",", "0.1", ",", "2"}], "}"}], ",", 
   RowBox[{"LabelStyle", "\[Rule]", 
    RowBox[{"Directive", "[", 
     RowBox[{"Bold", ",", " ", "Medium"}], "]"}]}]}], "]"}]}], "Input",
