Cell["\<\
Solve for non-identity covariance:
\
\>", "Text",
 CellChangeTimes->{{3.9434268448534403`*^9, 3.9434268574058743`*^9}, {
  3.9434268940704613`*^9, 
  3.94342689458581*^9}},ExpressionUUID->"97a291ce-7b86-4d9c-9d09-\
2d6b3b53f626"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "\[Lambda]", ",", "\[Sigma]", ",", "\[Alpha]", ",", "q", ",", "f", ",", 
   "g"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"w", "[", 
    RowBox[{"\[Lambda]_", ",", "q_"}], "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"\[Alpha]", 
      RowBox[{"(", 
       RowBox[{"q", "-", "1"}], ")"}]}], 
     RowBox[{"2", 
      SuperscriptBox["\[Sigma]", "2"]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SqrtBox[
       FractionBox[
        RowBox[{"1", "-", "\[Lambda]", "+", 
         RowBox[{"q", "*", "\[Lambda]"}], "+", 
         RowBox[{"3", 
          SuperscriptBox["\[Sigma]", "2"]}]}], 
        RowBox[{"1", "-", "\[Lambda]", "+", 
         RowBox[{"q", "*", "\[Lambda]"}], "-", 
         SuperscriptBox["\[Sigma]", "2"]}]]]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "q_", "]"}], ":=", 
   RowBox[{"\[Alpha]", 
    RowBox[{"(", 
     RowBox[{"q", "-", "1"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       FractionBox[
        RowBox[{"\[Lambda]", 
         RowBox[{"(", 
          RowBox[{"q", "-", "1"}], ")"}]}], 
        RowBox[{"2", 
         SuperscriptBox["\[Sigma]", "2"]}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SqrtBox[
          FractionBox[
           RowBox[{"1", "-", 
            RowBox[{"\[Lambda]", 
             RowBox[{"(", 
              RowBox[{"1", "-", "q"}], ")"}]}], "+", 
            RowBox[{"3", 
             SuperscriptBox["\[Sigma]", "2"]}]}], 
           RowBox[{"1", "-", 
            RowBox[{"\[Lambda]", 
             RowBox[{"(", 
              RowBox[{"1", "-", "q"}], ")"}]}], "-", 
            SuperscriptBox["\[Sigma]", "2"]}]]]}], ")"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"s", "=", 
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{"q", "==", 
      RowBox[{"f", "[", "q", "]"}]}], ",", "q"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "\[Lambda]_", "]"}], ":=", 
   RowBox[{"q", "/.", 
    RowBox[{"s", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "[", "\[Lambda]_", "]"}], " ", ":=", 
   RowBox[{"q", "/.", 
    RowBox[{"s", "[", 
     RowBox[{"[", "4", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]", "=", "0.92"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"\[Lambda]_", ",", "\[Sigma]_"}], "]"}], ":=", " ", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Pi]", "*", "\[Alpha]"}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"w", "[", 
        RowBox[{"\[Lambda]", ",", 
         RowBox[{"g", "[", "\[Lambda]", "]"}]}], "]"}], "]"}], "+", 
      RowBox[{"Im", "[", 
       RowBox[{"w", "[", 
        RowBox[{"\[Lambda]", ",", 
         RowBox[{"h", "[", "\[Lambda]", "]"}]}], "]"}], "]"}]}], ")"}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"u", "[", 
    RowBox[{"\[Lambda]", ",", "\[Sigma]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Lambda]", ",", "0", ",", "10"}], "}"}], ",", 
   RowBox[{"Filling", "->", "Axis"}], ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], "Input",
